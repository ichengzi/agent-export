{
  "name": "agent-export",
  "version": "0.1.1",
  "description": "export codex or claude code sessions to a single interactive HTML file.",
  "type": "module",
  "bin": {
    "agent-export": "./bin/agent-export.js"
  },
  "exports": {
    ".": "./src/cli.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "node --check ./src/cli.js",
    "check:bin": "node --check ./bin/agent-export.js"
  },
  "keywords": [
    "codex",
    "claude",
    "session",
    "export",
    "html",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
